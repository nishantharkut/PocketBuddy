MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=pocketbuddy

# Optional demo-only phone login UI. Keep false unless the backend has
# DEMO_PHONE_AUTH_ENABLED=true and the tradeoff is acceptable for a demo.
VITE_DEMO_PHONE_AUTH_ENABLED=false

# Optional public webhook URL used inside Android connector pairing links.
# Use this for physical-phone demos because phones cannot reach laptop localhost.
# Example: http://192.168.1.25:8000/api/ingest/notification-v2
VITE_CONNECTOR_WEBHOOK_URL=
