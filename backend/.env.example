JWT_SECRET=YOUR_64_CHAR_SECRET_HERE_REPLACE_ME_BEFORE_PROD
MONGO_URI=mongodb://localhost:27017
PORT=8000
# Travel uses OpenStreetMap-compatible providers by default.
# For production, point these to self-hosted or dedicated provider instances.
PHOTON_GEOCODER_URL=https://photon.komoot.io
NOMINATIM_GEOCODER_URL=https://nominatim.openstreetmap.org
OSRM_ROUTE_URL=https://router.project-osrm.org
TRAVEL_GEO_USER_AGENT=PocketBuddy-TravelGuard/1.0 (https://github.com/nishantharkut/PocketBuddy)
TRAVEL_GEO_CACHE_ENABLED=true
TRAVEL_GEOCODE_CACHE_TTL_DAYS=30
TRAVEL_ROUTE_CACHE_TTL_DAYS=7
# Optional: traffic-aware routing/ETA. If empty, Travel falls back to OSRM.
TOMTOM_API_KEY=
TOMTOM_ROUTE_URL=https://api.tomtom.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=ap-south-1
CAMPUS_FOOD_S3_BUCKET=
CAMPUS_FOOD_S3_KEY=campus_food.json
BEDROCK_ENABLED=false
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=us.amazon.nova-lite-v1:0
TRAVEL_DEMO_MODE=false

# Meta WhatsApp Cloud API credentials
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_TOKEN=

# Twilio WhatsApp API credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Frontend base URL (CloudFront domain in production, e.g. https://d3g6cg7q9hn7hi.cloudfront.net)
FRONTEND_BASE_URL=http://localhost:5173

# Demo-only phone auth. Keep false unless intentionally demonstrating the
# placeholder phone flow; production requires a real OTP provider.
DEMO_PHONE_AUTH_ENABLED=false
# Seven days. Lower this for production if you want shorter browser sessions.
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Android connector trust boundary. Keep legacy raw ingest disabled unless
# migrating an older APK that still posts raw notification text.
CONNECTOR_LEGACY_RAW_INGEST_ENABLED=false
CONNECTOR_SIGNATURE_REQUIRED=false
CONNECTOR_SIGNATURE_TOLERANCE_SECONDS=300

# Account Aggregator sandbox integration
# Keep disabled unless you are explicitly testing AA sandbox flows.
AA_SANDBOX_ENABLED=false
# local = PocketBuddy's built-in dummy-data sandbox lifecycle.
# Provider sandboxes require FIU credentials and provider-specific onboarding.
AA_SANDBOX_PROVIDER=local
AA_SANDBOX_BASE_URL=
AA_CLIENT_ID=
AA_CLIENT_SECRET=
AA_FIU_ID=
AA_CALLBACK_SECRET=
# Optional JSON endpoint for a provider-backed AA institution/FIP registry.
# Expected shape: [{"id":"...", "name":"...", "short_name":"...", "type":"Bank", "regulator":"RBI", "status":"Live", "domain":"...", "logo_url":"..."}]
# or {"institutions":[...]}.
AA_INSTITUTION_REGISTRY_URL=

# Explicitly enable demo-only seed/fallback data for local demos only.
DEMO_MODE=false
OCR_PROVIDER=ocrspace
OCR_SPACE_API_KEY=
